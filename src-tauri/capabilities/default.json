{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for all windows",
  "windows": ["main"],
  "platforms": ["macOS", "windows"],
  "permissions": [
    "core:default",
    "core:webview:allow-print",
    "opener:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart",
    "process:allow-exit"
  ]
}
